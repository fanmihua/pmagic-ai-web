{
  "version": 2,
  "installCommand": "npm install --include=optional",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": false
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "server/dist/**"
    }
  }
}
