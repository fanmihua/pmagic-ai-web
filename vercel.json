{
  "version": 2,
  "installCommand": "npm install --include=optional",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin",
      "status": 307,
      "headers": {
        "Location": "/admin/"
      }
    },
    {
      "src": "/admin/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=2592000, stale-while-revalidate=86400"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "server/dist/**"
    }
  }
}
